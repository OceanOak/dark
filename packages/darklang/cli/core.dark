module Darklang.Cli

type SubAppAction =
  | Continue
  | Save
  | Exit
  /// Hand off to another command (e.g. a browser launching a foreground app), replacing this page.
  | LaunchCommand of String

type SubApp =
  { onKey: Stdlib.Cli.Stdin.Key.Key -> Stdlib.Cli.Stdin.Modifiers.Modifiers -> Stdlib.Option.Option<String> -> (SubAppAction * SubApp)
    onDisplay: Unit -> Unit
    onSave: Unit -> Unit
    /// Restore the app's terminal surface when the CLI exits on Ctrl-C,
    /// bypassing the app's own exit action. Safe when already stopped.
    onTerminate: Unit -> Unit }

type Page =
  | MainPrompt
  | InteractiveNav of Packages.NavInteractive.Session
  | CompletionPicker of CompletionPicker.Session
  | SubApp of SubApp

type AppState =
  { isExiting: Bool
    prompt: Prompt.State
    packageData: Packages.State
    currentPage: Page
    currentBranchId: Uuid
    accountID: Stdlib.Option.Option<Uuid>
    accountName: String
    /// Retained presentation state while the main prompt owns an inline region.
    promptTerminal: Stdlib.Option.Option<Tui.TerminalSession.State>
    /// True when invoked from the command line (not the interactive REPL)
    nonInteractive: Bool
    /// Cached completion hint — skip recompute when prompt text unchanged
    cachedHintInput: String
    cachedHintValue: String
    /// Cached command list and option strings — built once at startup
    allCommandsCache: List<Registry.CommandHandler>
    commandOptionsCache: List<String>
    /// When true, write telemetry to rundir/logs/telemetry.jsonl
    telemetryEnabled: Bool }

let locationStr (state: AppState) : String =
  Packages.formatLocation state.packageData.currentLocation

let commandOptions () : List<String> =
  let commands = Registry.allCommands ()
  let allNames = Stdlib.List.map commands (fun cmd -> cmd.name)
  let allAliases = Stdlib.List.fold commands [] (fun acc cmd -> Stdlib.List.append acc cmd.aliases)
  Stdlib.List.append allNames allAliases

// Restore the persisted account from cli-config.json (written by
// `login`). Returns (None, "") if the file is absent / the entry is
// missing / the account no longer exists.
let restoreSessionAccount () : (Stdlib.Option.Option<Uuid> * String) =
  match Config.get "session.account_id" with
  | None -> (Stdlib.Option.Option.None, "")
  | Some idStr ->
    match Stdlib.Uuid.parse idStr with
    | Error _ -> (Stdlib.Option.Option.None, "")
    | Ok id ->
      match SCM.Account.getById id with
      | None -> (Stdlib.Option.Option.None, "")
      | Some account ->
        (Stdlib.Option.Option.Some account.id, account.name)


/// Where a CLI run starts, absent a `--branch` flag: `DARK_BRANCH` if set, else the `branch.default` you
/// configured (`dark branch default <name>`), else main.
///
/// That order is the usual one — flag beats env beats config beats default — and each rung is scoped tighter
/// than the one below: the flag is this command, DARK_BRANCH is this shell (so concurrent runs don't stomp
/// each other), the config is this machine.
let resolveBranchName (name: String) (source: String) : Uuid =
  match SCM.Branch.getByName name with
  | Some b -> b.id
  | None ->
    Stdlib.printLine
      (Colors.error $"Warning: {source} '{name}' not found, using main.")
    SCM.Branch.mainBranchId

let resolveStartingBranch () : Uuid =
  let mainId = SCM.Branch.mainBranchId

  let fromEnv =
    match Builtin.environmentGet "DARK_BRANCH" with
    | Some name ->
      if Stdlib.String.isEmpty name then
        Stdlib.Option.Option.None
      else
        Stdlib.Option.Option.Some name
    | None -> Stdlib.Option.Option.None

  match fromEnv with
  | Some name -> resolveBranchName name "DARK_BRANCH="
  | None ->
    match Darklang.Cli.Config.get "branch.default" with
    | Some name ->
      if Stdlib.String.isEmpty name then
        mainId
      else
        resolveBranchName name "default branch"
    | None -> mainId


let initState () : AppState =
  let (accountID, accountName) = restoreSessionAccount ()
  let branchId = resolveStartingBranch ()
  AppState
    { isExiting = false
      prompt = Prompt.initState ()
      packageData = Packages.initState ()
      currentPage = Page.MainPrompt
      currentBranchId = branchId
      accountID = accountID
      accountName = accountName
      promptTerminal = Stdlib.Option.Option.None
      nonInteractive = false
      cachedHintInput = ""
      cachedHintValue = ""
      allCommandsCache = Registry.allCommands ()
      commandOptionsCache = commandOptions ()
      telemetryEnabled = (Builtin.environmentGet "DARK_TELEMETRY") == Stdlib.Option.Option.Some "1" }

type Msg =
  | ProcessInput of String
  | KeyPressed of key: Stdlib.Cli.Stdin.Key.Key * modifiers: Stdlib.Cli.Stdin.Modifiers.Modifiers * keyChar: Stdlib.Option.Option<String>
  | Exit


module ExecutionError =
  /// Host-side exception that escaped the normal error path. `metadata` is
  /// a string map; the F# host pre-stringifies values since `Exception.toMetadata`
  /// only ever produces strings.
  type Unhandled =
    { message: String
      metadata: List<(String * String)> }

  /// Boundary type for CLI command failures. Each variant carries its own
  /// structured payload — no flattening to strings at the boundary.
  type ExecutionError =
    | Parse of LanguageTools.Parser.CliScript.ParseError
    | Runtime of LanguageTools.RuntimeTypes.RuntimeError.Error
    | Unhandled of Unhandled

  let toString (branchId: Uuid) (err: ExecutionError) : String =
    match err with
    | Parse pe -> LanguageTools.Parser.CliScript.ParseError.toString pe
    | Runtime rte ->
      PrettyPrinter.RuntimeTypes.RuntimeError.toString branchId rte
    | Unhandled u ->
      match u.metadata with
      | [] -> $"Internal error: {u.message}"
      | _ ->
        let lines =
          u.metadata
          |> Stdlib.List.map (fun (k, v) -> $"  {k}: {v}")
          |> Stdlib.String.join "\n"
        $"Internal error: {u.message}\n{lines}"


module View =
  let formatError (message: String) : String =
    Colors.error ("Error: " ++ message)

  let formatSuccess (message: String) : String =
    Colors.success message

  let formatWelcome () : String = Registry.getCompactCommandList ()


module Registry =
